class Solution:
    def countRoutes(self, locations, start, finish, fuel):
        MOD = 10**9 + 7
        n = len(locations)
        memo = {}
        
        def dfs(i, f):
            if (i, f) in memo:
                return memo[(i, f)]
            
            res = 1 if i == finish else 0
            
            for j in range(n):
                if i != j:
                    cost = abs(locations[i] - locations[j])
                    if f >= cost:
                        res = (res + dfs(j, f - cost)) % MOD
            
            memo[(i, f)] = res
            return res
        
        return dfs(start, fuel)
