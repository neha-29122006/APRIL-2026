class Solution:
    def toHex(self, num: int) -> str:
        # Handle zero case
        if num == 0:
            return "0"
        
        # Convert negative number to 32-bit unsigned equivalent
        if num < 0:
            num += 1 << 32
        
        digits = "0123456789abcdef"
        result = []
        
        # Extract hex digits
        while num > 0:
            result.append(digits[num & 15])  # num % 16
            num >>= 4  # divide by 16
        
        # Reverse to get correct order
        return ''.join(reversed(result))
